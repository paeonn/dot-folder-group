{
  "name": "dot-folder-group",
  "displayName": "Dot Folder Group",
  "description": "Keep your Explorer clean by grouping all dot-folders (.vscode, .github, .cursor...) under a single collapsible node.",
  "version": "0.1.3",
  "publisher": "Paeon",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Dot Folder Group",
      "properties": {
        "dotFolderGroup.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable dot-folder grouping"
        },
        "dotFolderGroup.hideInExplorer": {
          "type": "boolean",
          "default": true,
          "description": "Hide dot-folders from the default Explorer (they appear only in the group)"
        },
        "dotFolderGroup.groupLabel": {
          "type": "string",
          "default": ".",
          "description": "Label for the root node that groups dot-folders"
        },
        "dotFolderGroup.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [".git"],
          "description": "Dot-folder names that should not be grouped or hidden"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "dotFolderGroup.explorer",
          "name": "Dot Folders",
          "when": "dotFolderGroup.enabled && dotFolderGroup.hasFolders"
        }
      ]
    },
    "commands": [
      {
        "command": "dotFolderGroup.refresh",
        "title": "Refresh Dot Folders",
        "icon": "$(refresh)"
      },
      {
        "command": "dotFolderGroup.toggleHide",
        "title": "Dot Folder Group: Toggle Hide Dot-Folders in Explorer"
      },
      {
        "command": "dotFolderGroup.revealInGroup",
        "title": "Reveal in Dot Folder Group"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dotFolderGroup.refresh",
          "when": "view == dotFolderGroup.explorer",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "dotFolderGroup.revealInGroup",
          "when": "dotFolderGroup.enabled && resourceFilename =~ /^\\./",
          "group": "2_workspace@9"
        }
      ]
    }
  }
}
